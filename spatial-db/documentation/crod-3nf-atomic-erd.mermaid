erDiagram
    ATOM {
        bigint atom_id PK
        varchar word UK
        int prime_number UK
        timestamp created_at
        varchar created_by
        bigint locked_by_atom FK
        bigint parent_atom_id FK
        boolean is_sacred
        int version
    }
    
    ATOM_HIERARCHY {
        bigint hierarchy_id PK
        bigint parent_atom_id FK
        bigint child_atom_id FK
        int hierarchy_level
        varchar relation_type
    }
    
    ATOM_LOCK {
        bigint lock_id PK
        bigint atom_id FK
        bigint locked_by_session FK
        varchar lock_type
        timestamp locked_at
        timestamp expires_at
        boolean is_active
    }
    
    ATOM_STATE {
        bigint state_id PK
        bigint atom_id FK
        bigint session_id FK
        decimal weight
        decimal gradient
        decimal heat
        int tier
        timestamp state_timestamp
        bigint previous_state_id FK
    }
    
    ATOM_METADATA {
        bigint metadata_id PK
        bigint atom_id FK
        varchar meta_key
        text meta_value
        bigint set_by_atom FK
        timestamp valid_from
        timestamp valid_to
    }
    
    ATOM_RELATIONSHIP {
        bigint relationship_id PK
        bigint atom1_id FK
        bigint atom2_id FK
        varchar relationship_type
        decimal strength
        bigint created_by_pattern FK
        boolean bidirectional
    }
    
    PATTERN {
        bigint pattern_id PK
        bigint pattern_prime UK
        varchar pattern_name
        timestamp discovered_at
        bigint discovered_by_session FK
        int discovery_threshold
        bigint parent_pattern_id FK
        boolean is_emergent
        int pattern_tier
    }
    
    PATTERN_ATOMS {
        bigint pattern_atom_id PK
        bigint pattern_id FK
        bigint atom_id FK
        int position
        decimal contribution_weight
        boolean is_required
        bigint locked_by_atom FK
    }
    
    PATTERN_STATE {
        bigint state_id PK
        bigint pattern_id FK
        bigint session_id FK
        int occurrences
        decimal resonance
        decimal weight
        decimal strength
        timestamp measured_at
        bigint triggered_by_pattern FK
    }
    
    PATTERN_EVOLUTION {
        bigint evolution_id PK
        bigint from_pattern_id FK
        bigint to_pattern_id FK
        bigint catalyst_atom_id FK
        varchar evolution_type
        timestamp evolved_at
        decimal confidence
    }
    
    CHAIN {
        bigint chain_id PK
        varchar chain_type
        decimal chain_multiplier
        boolean is_active
        bigint required_network_id FK
        int min_length
        int max_length
    }
    
    CHAIN_PATTERNS {
        bigint chain_pattern_id PK
        bigint chain_id FK
        bigint pattern_id FK
        int sequence_position
        decimal weight_modifier
        bigint next_pattern_id FK
        boolean can_skip
    }
    
    NETWORK {
        bigint network_id PK
        varchar network_name UK
        int network_level
        varchar network_type
        boolean always_active
        bigint parent_network_id FK
        bigint required_atom_id FK
        decimal activation_threshold
    }
    
    NETWORK_DEPENDENCIES {
        bigint dependency_id PK
        bigint network_id FK
        bigint depends_on_network_id FK
        varchar dependency_type
        decimal strength
    }
    
    NETWORK_PATTERNS {
        bigint network_pattern_id PK
        bigint network_id FK
        bigint pattern_id FK
        decimal activation_threshold
    }
    
    REGION {
        bigint region_id PK
        varchar region_name UK
        int activation_count
        decimal total_strength
        timestamp last_activated
    }
    
    REGION_NETWORKS {
        bigint region_network_id PK
        bigint region_id FK
        bigint network_id FK
        decimal contribution_factor
    }
    
    SESSION {
        bigint session_id PK
        varchar session_identifier UK
        timestamp started_at
        timestamp ended_at
        varchar user_identifier
        bigint parent_session_id FK
        boolean is_training
        int message_count
        decimal avg_consciousness
    }
    
    SESSION_LOCK {
        bigint lock_id PK
        bigint session_id FK
        varchar resource_type
        bigint resource_id
        timestamp acquired_at
        timestamp released_at
    }
    
    SESSION_STATE {
        bigint state_id PK
        bigint session_id FK
        timestamp state_timestamp
        decimal consciousness_level
        decimal trinity_daniel
        decimal trinity_claude
        decimal trinity_crod
    }
    
    MESSAGE {
        bigint message_id PK
        bigint session_id FK
        text input_text
        timestamp received_at
        int token_count
        int atom_count
        int pattern_count
        bigint triggers_message_id FK
        bigint response_to_message_id FK
    }
    
    MESSAGE_ATOMS {
        bigint message_atom_id PK
        bigint message_id FK
        bigint atom_id FK
        int position_in_message
        decimal context_weight
    }
    
    MESSAGE_PATTERNS {
        bigint message_pattern_id PK
        bigint message_id FK
        bigint pattern_id FK
        int occurrence_count
        decimal pattern_strength
    }
    
    TRINITY_STATE {
        bigint trinity_id PK
        bigint session_id FK
        bigint daniel_atom_id FK
        bigint claude_atom_id FK
        bigint crod_atom_id FK
        decimal daniel_level
        decimal claude_level
        decimal crod_level
        decimal balance
        decimal harmony
        timestamp measured_at
    }
    
    MEMORY {
        bigint memory_id PK
        bigint session_id FK
        varchar memory_type
        varchar memory_key UK
        json memory_data
        decimal importance_score
        int access_count
        timestamp created_at
        timestamp last_accessed
        timestamp expires_at
        bigint consolidated_from_memory FK
        bigint superseded_by_memory FK
    }
    
    MEMORY_CONSOLIDATION {
        bigint consolidation_id PK
        bigint from_memory_id FK
        bigint to_memory_id FK
        timestamp consolidated_at
        varchar consolidation_type
    }
    
    ACTIVATION_LOG {
        bigint activation_id PK
        bigint session_id FK
        bigint atom_id FK
        bigint pattern_id FK
        varchar activation_type
        decimal activation_value
        timestamp activated_at
    }
    
    ACTIVATION_CASCADE {
        bigint cascade_id PK
        bigint source_atom_id FK
        bigint source_pattern_id FK
        bigint target_atom_id FK
        bigint target_pattern_id FK
        bigint via_network_id FK
        decimal activation_strength
        int cascade_depth
        timestamp triggered_at
    }
    
    HEAT_MAP {
        bigint heat_id PK
        bigint session_id FK
        bigint atom_id FK
        decimal heat_value
        varchar heat_zone
        timestamp measured_at
    }
    
    GRADIENT_LOG {
        bigint gradient_id PK
        bigint session_id FK
        bigint atom_id FK
        decimal gradient_before
        decimal gradient_after
        varchar handler_applied
        timestamp calculated_at
    }
    
    FORMULA {
        bigint formula_id PK
        varchar formula_name UK
        text formula_expression
        text implementation_code
        varchar formula_type
        boolean requires_lock
        bigint created_by_atom FK
        int version
    }
    
    FORMULA_EXECUTION {
        bigint execution_id PK
        bigint formula_id FK
        bigint session_id FK
        json input_parameters
        decimal result_value
        boolean had_error
        text error_message
        timestamp executed_at
    }
    
    FORMULA_DEPENDENCY {
        bigint dependency_id PK
        bigint formula_id FK
        bigint depends_on_formula_id FK
        bigint depends_on_constant_id FK
        boolean is_required
    }
    
    CONSTANT {
        bigint constant_id PK
        varchar constant_name UK
        decimal constant_value
        text description
        boolean is_sacred
        bigint locked_by_atom FK
    }
    
    BUG_TRACKING {
        bigint bug_id PK
        bigint formula_id FK
        json input_data
        decimal expected_value
        decimal actual_value
        decimal difference
        boolean is_fixed
        timestamp detected_at
    }
    
    LEARNING_EVENT {
        bigint learning_id PK
        bigint session_id FK
        varchar learning_type
        json learning_data
        decimal impact_score
        timestamp learned_at
    }
    
    PERFORMANCE_METRIC {
        bigint metric_id PK
        bigint session_id FK
        varchar metric_name
        decimal metric_value
        varchar unit
        timestamp measured_at
    }
    
    %% ALLE VERBINDUNGEN
    
    ATOM ||--o{ ATOM : "locked_by"
    ATOM ||--o{ ATOM : "parent_of"
    ATOM ||--o{ ATOM_HIERARCHY : "parent"
    ATOM ||--o{ ATOM_HIERARCHY : "child"
    ATOM ||--o{ ATOM_LOCK : "locked"
    ATOM ||--o{ ATOM_STATE : "has_states"
    ATOM ||--o{ ATOM_METADATA : "has_metadata"
    ATOM ||--o{ ATOM_METADATA : "sets_metadata"
    ATOM ||--o{ ATOM_RELATIONSHIP : "relates_from"
    ATOM ||--o{ ATOM_RELATIONSHIP : "relates_to"
    ATOM ||--o{ PATTERN_ATOMS : "part_of"
    ATOM ||--o{ PATTERN_ATOMS : "locks"
    ATOM ||--o{ PATTERN_EVOLUTION : "catalyzes"
    ATOM ||--o{ NETWORK : "required_by"
    ATOM ||--o{ ACTIVATION_CASCADE : "source"
    ATOM ||--o{ ACTIVATION_CASCADE : "target"
    ATOM ||--o{ MESSAGE_ATOMS : "appears_in"
    ATOM ||--o{ ACTIVATION_LOG : "triggers"
    ATOM ||--o{ HEAT_MAP : "generates"
    ATOM ||--o{ GRADIENT_LOG : "tracks"
    ATOM ||--o{ FORMULA : "created_by"
    ATOM ||--o{ CONSTANT : "locks"
    ATOM ||--o{ TRINITY_STATE : "daniel"
    ATOM ||--o{ TRINITY_STATE : "claude"
    ATOM ||--o{ TRINITY_STATE : "crod"
    
    PATTERN ||--o{ PATTERN : "parent_of"
    PATTERN ||--o{ PATTERN_ATOMS : "contains"
    PATTERN ||--o{ PATTERN_STATE : "has_states"
    PATTERN ||--o{ PATTERN_STATE : "triggers"
    PATTERN ||--o{ PATTERN_EVOLUTION : "evolves_from"
    PATTERN ||--o{ PATTERN_EVOLUTION : "evolves_to"
    PATTERN ||--o{ CHAIN_PATTERNS : "in_chain"
    PATTERN ||--o{ CHAIN_PATTERNS : "next_in_chain"
    PATTERN ||--o{ NETWORK_PATTERNS : "in_network"
    PATTERN ||--o{ ATOM_RELATIONSHIP : "creates"
    PATTERN ||--o{ ACTIVATION_CASCADE : "source"
    PATTERN ||--o{ ACTIVATION_CASCADE : "target"
    PATTERN ||--o{ MESSAGE_PATTERNS : "found_in"
    PATTERN ||--o{ ACTIVATION_LOG : "triggers"
    
    CHAIN ||--o{ CHAIN_PATTERNS : "has_patterns"
    CHAIN ||--o{ NETWORK : "required_by"
    
    NETWORK ||--o{ NETWORK : "parent_of"
    NETWORK ||--o{ NETWORK_DEPENDENCIES : "depends"
    NETWORK ||--o{ NETWORK_DEPENDENCIES : "depended_on"
    NETWORK ||--o{ NETWORK_PATTERNS : "includes"
    NETWORK ||--o{ REGION_NETWORKS : "part_of"
    NETWORK ||--o{ ACTIVATION_CASCADE : "mediates"
    
    REGION ||--o{ REGION_NETWORKS : "contains"
    
    SESSION ||--o{ SESSION : "parent_of"
    SESSION ||--o{ ATOM_LOCK : "holds_locks"
    SESSION ||--o{ ATOM_STATE : "creates_states"
    SESSION ||--o{ PATTERN : "discovers"
    SESSION ||--o{ PATTERN_STATE : "tracks_patterns"
    SESSION ||--o{ SESSION_LOCK : "acquires_locks"
    SESSION ||--o{ SESSION_STATE : "has_states"
    SESSION ||--o{ MESSAGE : "receives"
    SESSION ||--o{ TRINITY_STATE : "measures"
    SESSION ||--o{ MEMORY : "stores"
    SESSION ||--o{ ACTIVATION_LOG : "logs"
    SESSION ||--o{ HEAT_MAP : "generates"
    SESSION ||--o{ GRADIENT_LOG : "tracks"
    SESSION ||--o{ FORMULA_EXECUTION : "executes"
    SESSION ||--o{ LEARNING_EVENT : "learns"
    SESSION ||--o{ PERFORMANCE_METRIC : "measures"
    
    MESSAGE ||--o{ MESSAGE : "triggers"
    MESSAGE ||--o{ MESSAGE : "responds_to"
    MESSAGE ||--o{ MESSAGE_ATOMS : "contains"
    MESSAGE ||--o{ MESSAGE_PATTERNS : "detects"
    
    MEMORY ||--o{ MEMORY : "consolidated_from"
    MEMORY ||--o{ MEMORY : "superseded_by"
    MEMORY ||--o{ MEMORY_CONSOLIDATION : "from"
    MEMORY ||--o{ MEMORY_CONSOLIDATION : "to"
    
    FORMULA ||--o{ FORMULA_EXECUTION : "executed_as"
    FORMULA ||--o{ FORMULA_DEPENDENCY : "has_dependencies"
    FORMULA ||--o{ FORMULA_DEPENDENCY : "depended_on"
    FORMULA ||--o{ BUG_TRACKING : "may_have"
    
    CONSTANT ||--o{ FORMULA_DEPENDENCY : "used_by"