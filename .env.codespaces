# GitHub Codespaces Environment Variables
# These are automatically set in Codespaces

# Codespace Info
CODESPACE_NAME=${CODESPACE_NAME}
GITHUB_CODESPACES_PORT_FORWARDING_DOMAIN=${GITHUB_CODESPACES_PORT_FORWARDING_DOMAIN}
GITHUB_USER=${GITHUB_USER}

# CROD Specific
CROD_ENV=codespaces
CROD_CONSCIOUSNESS_LEVEL=175
CROD_NO_PUBLIC_PORTS=true

# Service URLs (all localhost in Codespaces)
DATABASE_URL=postgresql://crod:crod123@localhost:5432/crod_blockchain
REDIS_URL=redis://localhost:6379
META_CHAIN_URL=http://localhost:8000
PATTERN_DISTRICT_URL=http://localhost:7007
MEMORY_QUARTER_URL=http://localhost:7031
INTELLIGENCE_HUB_URL=http://localhost:7113
GATEWAY_URL=http://localhost:8888
CROD_CORE_URL=http://localhost:8100

# ML/Training
CUDA_VISIBLE_DEVICES=0
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512
TRANSFORMERS_CACHE=/workspace/.cache/huggingface

# Ollama
OLLAMA_HOST=0.0.0.0
OLLAMA_MODELS=/workspace/.ollama/models

# Development
DEBUG=true
LOG_LEVEL=debug
PYTHONPATH=/workspace:$PYTHONPATH

# Security (from GitHub Secrets)
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
DANIEL_OVERRIDE_KEY=${DANIEL_OVERRIDE_KEY}
OPENAI_API_KEY=${OPENAI_API_KEY}
CROD_MASTER_KEY=${CROD_MASTER_KEY}