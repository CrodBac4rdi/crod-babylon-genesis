{
  "name": "CROD 2025 - Minimal",
  "image": "mcr.microsoft.com/devcontainers/universal:2-linux",
  
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {},
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/rust:1": {},
    "ghcr.io/devcontainers/features/go:1": {},
    "ghcr.io/devcontainers-contrib/features/elixir-asdf:2": {}
  },
  
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "rust-lang.rust-analyzer",
        "golang.go",
        "jakebecker.elixir-ls",
        "Continue.continue",
        "Gruntfuggly.todo-tree"
      ]
    }
  },
  
  // Auto-forward CROD ports
  "forwardPorts": [3456, 5000, 5173, 7777, 8765],
  
  "portsAttributes": {
    "5173": { "label": "CROD Web Interface", "onAutoForward": "openBrowser" },
    "5000": { "label": "CROD Visualization Studio", "onAutoForward": "notify" },
    "3456": { "label": "CROD Live API", "onAutoForward": "notify" },
    "7777": { "label": "CROD Parasite AI", "visibility": "private" },
    "8765": { "label": "CROD WebSocket", "onAutoForward": "silent" }
  },
  
  // Auto-start CROD on container start
  "postStartCommand": "bash .devcontainer/start-crod-auto.sh",
  
  "remoteEnv": {
    "DANIEL_OVERRIDE_KEY": "${localEnv:DANIEL_OVERRIDE_KEY}"
  }
}