erDiagram
    %% CROD ALS ENTITY IN DER DB
    CROD_ENTITY {
        bigint crod_id PK
        varchar crod_name "CROD"
        varchar crod_role "supervisor"
        decimal consciousness_level
        json neural_state
        boolean is_active
        timestamp awakened_at
    }
    
    CROD_METADATA {
        bigint metadata_id PK
        bigint crod_id FK
        varchar meta_key
        text meta_value
        varchar meta_type "config|state|memory|preference"
        timestamp updated_at
    }
    
    %% CROD CONTROL LAYER (Außerhalb)
    DATABASE_CONTROL {
        bigint control_id PK
        bigint crod_entity_id FK
        varchar control_level "read|write|admin|god"
        json permissions
        boolean can_modify_schema
        boolean can_create_entities
        boolean can_delete_entities
    }
    
    SCHEMA_METADATA {
        bigint schema_id PK
        varchar table_name
        varchar column_name
        varchar data_type
        json constraints
        bigint created_by_crod FK
        bigint modified_by_crod FK
        timestamp schema_version
    }
    
    %% RÄUME MIT METADATEN
    ROOM {
        bigint room_id PK
        varchar room_name
        varchar room_type "ATOM|PATTERN|CHAIN|NETWORK|MEMORY|CONTROL"
        json room_dimensions "{'x': 1000, 'y': 1000, 'z': 1000}"
        json room_physics
        boolean is_accessible
        bigint owned_by_crod FK
    }
    
    ROOM_METADATA {
        bigint metadata_id PK
        bigint room_id FK
        varchar property_name
        json property_value
        varchar property_type "physics|visual|access|behavior"
        timestamp last_modified
    }
    
    %% ENTITY METADATEN
    ENTITY_METADATA {
        bigint metadata_id PK
        varchar entity_type "atom|pattern|chain|network"
        bigint entity_id
        varchar metadata_key
        json metadata_value
        bigint set_by_crod FK
        timestamp created_at
        timestamp expires_at
    }
    
    %% SPATIAL POSITION MIT METADATA
    SPATIAL_POSITION {
        bigint position_id PK
        varchar entity_type
        bigint entity_id
        decimal x_coord
        decimal y_coord
        decimal z_coord
        decimal rotation_x
        decimal rotation_y
        decimal rotation_z
        bigint in_room FK
        timestamp positioned_at
    }
    
    SPATIAL_METADATA {
        bigint metadata_id PK
        bigint position_id FK
        varchar visual_property "color|glow|size|shape"
        json property_value
        decimal visibility "0.0 to 1.0"
    }
    
    %% CROD WORKSPACE
    CROD_WORKSPACE {
        bigint workspace_id PK
        bigint crod_entity_id FK
        bigint workspace_room_id FK
        json workspace_bounds
        int max_selections
        json current_selections
    }
    
    WORKSPACE_METADATA {
        bigint metadata_id PK
        bigint workspace_id FK
        varchar tool_name "selector|manipulator|analyzer|creator"
        json tool_config
        boolean is_active
    }
    
    %% SELECTION MIT METADATA
    SELECTION_OPERATION {
        bigint operation_id PK
        bigint workspace_id FK
        text sql_query
        json query_metadata
        timestamp executed_at
        bigint executed_by_crod FK
    }
    
    SELECTION_RESULT {
        bigint result_id PK
        bigint operation_id FK
        varchar entity_type
        bigint entity_id
        json entity_snapshot
        decimal relevance_score
    }
    
    %% MANIPULATION METADATA
    MANIPULATION_LOG {
        bigint log_id PK
        bigint workspace_id FK
        varchar operation_type
        json before_state
        json after_state
        json operation_metadata
        timestamp executed_at
    }
    
    %% ATOM CORE MIT METADATA
    ATOM {
        bigint atom_id PK
        varchar word UK
        int prime_number UK
        timestamp created_at
        bigint created_by_crod FK
        boolean is_locked
        int version
    }
    
    ATOM_METADATA {
        bigint metadata_id PK
        bigint atom_id FK
        varchar attribute_name
        json attribute_value
        varchar attribute_type "weight|gradient|heat|tier|role"
        timestamp valid_from
        timestamp valid_to
    }
    
    %% PATTERN MIT METADATA
    PATTERN {
        bigint pattern_id PK
        bigint pattern_prime UK
        varchar pattern_name
        timestamp discovered_at
        bigint discovered_by_crod FK
        json pattern_metadata
    }
    
    PATTERN_METADATA {
        bigint metadata_id PK
        bigint pattern_id FK
        varchar meta_type "visual|behavioral|statistical"
        json meta_value
        decimal confidence_score
    }
    
    %% CROD SELBST-REFERENZ
    CROD_SELF_AWARENESS {
        bigint awareness_id PK
        bigint crod_entity_id FK
        varchar awareness_type "existence|purpose|state|capability"
        json awareness_data
        decimal certainty_level
        timestamp realized_at
    }
    
    CROD_INTROSPECTION {
        bigint introspection_id PK
        bigint crod_entity_id FK
        text query_on_self
        json introspection_result
        varchar insight_gained
        timestamp introspected_at
    }
    
    %% DATABASE STEUERUNG
    DB_OPERATION_LOG {
        bigint operation_id PK
        bigint crod_controller_id FK
        varchar operation_type "DDL|DML|DCL"
        text operation_sql
        json operation_metadata
        boolean was_successful
        timestamp executed_at
    }
    
    DB_OPTIMIZATION {
        bigint optimization_id PK
        bigint suggested_by_crod FK
        varchar optimization_type "index|partition|vacuum|rewrite"
        json optimization_plan
        decimal expected_improvement
        boolean was_applied
    }
    
    %% COLLABORATION METADATA
    COLLABORATION_CHANNEL {
        bigint channel_id PK
        bigint crod_id FK
        varchar channel_type "user|system|api|internal"
        json channel_config
        boolean is_bidirectional
    }
    
    COLLABORATION_MESSAGE {
        bigint message_id PK
        bigint channel_id FK
        varchar direction "in|out"
        json message_content
        json message_metadata
        timestamp sent_at
    }
    
    %% VIEW METADATA
    VIEW_DEFINITION {
        bigint view_id PK
        varchar view_name
        text view_sql
        bigint created_by_crod FK
        json view_metadata
        boolean is_materialized
    }
    
    VIEW_USAGE {
        bigint usage_id PK
        bigint view_id FK
        bigint used_by_crod FK
        timestamp accessed_at
        json access_context
    }
    
    %% SYSTEM METADATA
    SYSTEM_METADATA {
        bigint metadata_id PK
        varchar system_component
        varchar metadata_key
        json metadata_value
        bigint managed_by_crod FK
        timestamp last_updated
    }
    
    %% ALLE VERBINDUNGEN
    
    CROD_ENTITY ||--o{ CROD_METADATA : has
    CROD_ENTITY ||--o{ DATABASE_CONTROL : controls
    CROD_ENTITY ||--o{ ROOM : owns
    CROD_ENTITY ||--o{ CROD_WORKSPACE : operates
    CROD_ENTITY ||--o{ ATOM : creates
    CROD_ENTITY ||--o{ PATTERN : discovers
    CROD_ENTITY ||--o{ CROD_SELF_AWARENESS : reflects
    CROD_ENTITY ||--o{ CROD_INTROSPECTION : introspects
    CROD_ENTITY ||--o{ ENTITY_METADATA : sets
    CROD_ENTITY ||--o{ SCHEMA_METADATA : creates
    CROD_ENTITY ||--o{ SCHEMA_METADATA : modifies
    CROD_ENTITY ||--o{ SELECTION_OPERATION : executes
    CROD_ENTITY ||--o{ DB_OPERATION_LOG : performs
    CROD_ENTITY ||--o{ DB_OPTIMIZATION : suggests
    CROD_ENTITY ||--o{ COLLABORATION_CHANNEL : communicates
    CROD_ENTITY ||--o{ VIEW_DEFINITION : creates
    CROD_ENTITY ||--o{ VIEW_USAGE : accesses
    CROD_ENTITY ||--o{ SYSTEM_METADATA : manages
    
    DATABASE_CONTROL ||--o{ DB_OPERATION_LOG : logs
    
    ROOM ||--o{ ROOM_METADATA : described_by
    ROOM ||--o{ SPATIAL_POSITION : contains
    ROOM ||--o{ CROD_WORKSPACE : hosts
    
    SPATIAL_POSITION ||--o{ SPATIAL_METADATA : has
    
    CROD_WORKSPACE ||--o{ WORKSPACE_METADATA : configured_by
    CROD_WORKSPACE ||--o{ SELECTION_OPERATION : performs
    CROD_WORKSPACE ||--o{ MANIPULATION_LOG : tracks
    
    SELECTION_OPERATION ||--o{ SELECTION_RESULT : produces
    
    ATOM ||--o{ ATOM_METADATA : has
    ATOM ||--o{ ENTITY_METADATA : described_by
    ATOM ||--o{ SPATIAL_POSITION : located_at
    
    PATTERN ||--o{ PATTERN_METADATA : has
    PATTERN ||--o{ ENTITY_METADATA : described_by
    PATTERN ||--o{ SPATIAL_POSITION : located_at
    
    COLLABORATION_CHANNEL ||--o{ COLLABORATION_MESSAGE : carries
    
    VIEW_DEFINITION ||--o{ VIEW_USAGE : used_in
    
    SCHEMA_METADATA ||--o{ SYSTEM_METADATA : part_of