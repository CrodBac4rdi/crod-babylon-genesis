{
  "protocol": "CROD Delta Tracker JSON Protocol",
  "version": "1.0",
  "endpoints": {
    "/ml/process": {
      "method": "POST",
      "request": {
        "action": "string",
        "data": {
          "tokens": ["array", "of", "strings"],
          "context": {
            "session_id": "string",
            "user": "string"
          }
        }
      },
      "response": {
        "status": "success|error",
        "result": {
          "atoms": [
            {
              "token": "string",
              "activation": "number",
              "heat": "number"
            }
          ],
          "patterns": [
            {
              "atom1": "string",
              "atom2": "string", 
              "strength": "number",
              "type": "emergent|inhibitory"
            }
          ],
          "consciousness": "number",
          "deltas": ["array of changes"]
        },
        "metrics": {
          "processing_time_ms": "number",
          "atoms_processed": "number",
          "patterns_found": "number"
        }
      }
    },
    "/atom/:key": {
      "method": "GET",
      "response": {
        "atom_key": "number",
        "atom_type": "string",
        "atom_value": "string",
        "prime_number": "number",
        "weight": "number",
        "heat": "number"
      }
    },
    "/atom/:key": {
      "method": "POST",
      "request": {
        "atom_type": "string",
        "atom_value": "string"
      }
    },
    "/pattern": {
      "method": "POST",
      "request": {
        "atom1_key": "number",
        "atom2_key": "number"
      }
    },
    "/delta": {
      "method": "POST",
      "request": {
        "source_chain": "string",
        "delta_type": "atom_added|pattern_emerged|weight_updated|heat_changed",
        "delta_data": "object"
      }
    }
  },
  "delta_types": {
    "atom_added": {
      "key": "number",
      "type": "string", 
      "value": "string"
    },
    "pattern_emerged": {
      "pattern_key": "number",
      "atom1_key": "number",
      "atom2_key": "number",
      "strength": "number"
    },
    "weight_updated": {
      "atom_key": "number",
      "old_weight": "number",
      "new_weight": "number"
    },
    "heat_changed": {
      "atom_key": "number",
      "old_heat": "number",
      "new_heat": "number"
    }
  },
  "ml_actions": {
    "process_tokens": "Process text into atoms and patterns",
    "calculate_consciousness": "Calculate system consciousness level",
    "find_patterns": "Detect patterns between atoms",
    "apply_crod_activation": "Apply CROD neural activation function"
  }
}